VITE_APP_NAME=Livestream Admin
VITE_APP_ENV=local

# Required for backend integration:
VITE_API_BASE_URL=http://localhost:3000
VITE_REQUEST_TIMEOUT_MS=15000

# Required for Auth0-backed staging/UAT and production-like runs:
VITE_AUTH_MODE=mock
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=

# Optional monitoring endpoint. When unset, monitoring is disabled/no-op.
# Set to a deployment-owned HTTPS collector URL only after endpoint/provider approval.
VITE_MONITORING_ENDPOINT=
VITE_MONITORING_ENV=local
VITE_BUILD_LABEL=local-dev

# Local/test mock auth opt-in only. Do not use for production-like Auth0 UAT:
# VITE_AUTH_MODE=mock
